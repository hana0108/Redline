APP_NAME=Redline API
APP_ENV=development
DEBUG=true
API_V1_STR=/api/v1

# REQUIRED: generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY

ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+psycopg://redline:redline@localhost:5432/redline
DATABASE_SCHEMA=redline
ALLOWED_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500","http://red.elrealplatano.com"]
MEDIA_DIR=media
MEDIA_URL=/media
